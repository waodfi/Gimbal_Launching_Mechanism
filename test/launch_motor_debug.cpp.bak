// 蓄力电机（发射电机）按键触发调试程序
// 功能：按下按钮触发一次发射动作，用于测试每次发射转动角度
// 调参说明：
//   1. 修改 COUNTS_PER_360 直到实际转动360度时编码器计数准确
//   2. 修改 LAUNCH_ANGLE 设置每次发射转动角度
//   3. 修改 MOTOR_DIRECTION 调整电机转动方向

#include <Arduino.h>
#include <SPI.h>
#include <Wire.h>
#include <Adafruit_MotorShield.h>
#include "Config.h"

// ===== 蓄力电机配置 =====
constexpr uint8_t PIN_ENCODER_A = PIN_LAUNCH_ENCA;  // 使用发射编码器A相
constexpr uint8_t MOTOR_PORT = 1;                    // 发射电机在M1口
// 电机速度 0-255
// 蓄力发射需要高速+动能克服弹簧阻力，使用全速
// 如果弹簧阻力太大导致堵转，可以降到 200-220
constexpr uint8_t MOTOR_SPEED = 255;

// ===== 调参区域 =====
// 每圈编码器计数，需要实测调整：常见 3278(11线) 或 2086(7线)
constexpr long COUNTS_PER_360 = 3278;

// 电机方向控制：+1 = 正向，-1 = 反向
// 如果转动方向和预期相反，改成 -1
constexpr int8_t MOTOR_DIRECTION = 1;

// 每次发射转动角度（度）
// 根据实际机械结构调整，通常是拉满弹簧所需角度
constexpr int LAUNCH_ANGLE = 2030;

// 按钮防抖时间（毫秒）
constexpr unsigned long DEBOUNCE_MS = 50;

// ===== 控制参数 =====
constexpr long POSITION_TOLERANCE = 4;             // 位置容差
constexpr unsigned long MOVE_TIMEOUT_MS = 20000;   // 单次转动超时（1800度需要更长时间）

Adafruit_MotorShield shield;
Adafruit_DCMotor *motor = nullptr;

volatile long encoderCount = 0;
volatile int8_t motorDirection = 0;

bool lastStableState = HIGH;
bool lastRawState = HIGH;
unsigned long lastChangeTime = 0;
int launchCounter = 0;

void ISR_EncoderA() {
    encoderCount += motorDirection;
}

long readCount() {
    noInterrupts();
    long v = encoderCount;
    interrupts();
    return v;
}

void releaseMotor() {
    motorDirection = 0;
    motor->setSpeed(0);
    motor->run(RELEASE);
}

void rotateRelativeCounts(long delta) {
    const long start = readCount();
    
    // 应用方向控制参数
    const long adjustedDelta = delta * MOTOR_DIRECTION;
    const long target = start + adjustedDelta;
    
    motorDirection = (adjustedDelta > 0) ? 1 : -1;
    motor->setSpeed(MOTOR_SPEED);
    motor->run((adjustedDelta > 0) ? FORWARD : BACKWARD);

    const unsigned long t0 = millis();
    while (true) {
        const long err = target - readCount();
        if (labs(err) <= POSITION_TOLERANCE) {
            break;
        }
        if (millis() - t0 > MOVE_TIMEOUT_MS) {
            Serial.println(F("[WARN] Move timeout, stop motor."));
            break;
        }
        delay(1);
    }

    releaseMotor();
}

void setup() {
    Serial.begin(115200);
    delay(100);

    Serial.println(F("========================================"));
    Serial.println(F("蓄力电机（发射电机）按键触发调试程序"));
    Serial.println(F("========================================"));

    pinMode(PIN_TEST_FIRE_BTN, INPUT_PULLUP);
    pinMode(PIN_ENCODER_A, INPUT_PULLUP);
    delay(20);
    
    lastStableState = digitalRead(PIN_TEST_FIRE_BTN);
    lastRawState = lastStableState;
    
    Serial.print(F("[DIAG] 按钮引脚 D"));
    Serial.print(PIN_TEST_FIRE_BTN);
    Serial.print(F(" 初始电平: "));
    Serial.println(lastStableState ? F("HIGH") : F("LOW"));
    
    attachInterrupt(digitalPinToInterrupt(PIN_ENCODER_A), ISR_EncoderA, RISING);

    if (!shield.begin()) {
        Serial.println(F("[ERROR] Motor Shield 初始化失败"));
        while (true) {
            delay(100);
        }
    }

    motor = shield.getMotor(MOTOR_PORT);
    releaseMotor();

    Serial.println(F("[INFO] 初始化完成"));
    Serial.print(F("[INFO] 电机端口: M"));
    Serial.println(MOTOR_PORT);
    Serial.print(F("[INFO] 编码器引脚: D"));
    Serial.println(PIN_ENCODER_A);
    Serial.print(F("[INFO] 每次发射角度: "));
    Serial.print(LAUNCH_ANGLE);
    Serial.println(F("度"));
    Serial.print(F("[INFO] 电机方向: "));
    Serial.println(MOTOR_DIRECTION > 0 ? F("正向") : F("反向"));
    Serial.print(F("[INFO] 当前设定每圈计数: "));
    Serial.println(COUNTS_PER_360);
    Serial.print(F("[INFO] 触发按钮: D"));
    Serial.println(PIN_TEST_FIRE_BTN);
    Serial.println(F("[INFO] 按下按钮触发发射..."));
    Serial.println(F("========================================"));
    Serial.println(F("串口角度控制说明："));
    Serial.println(F("  输入正数：正向转动（如：360）"));
    Serial.println(F("  输入负数：反向转动（如：-360）"));
    Serial.println(F("  示例：输入 90 转动90度，输入 -180 反转180度"));
    Serial.println(F("========================================"));
    Serial.println();
}

void loop() {
    // ===== 串口输入角度控制 =====
    if (Serial.available() > 0) {
        int inputAngle = Serial.parseInt();
        
        // 清空串口缓冲区剩余字符
        while (Serial.available() > 0) {
            Serial.read();
        }
        
        if (inputAngle != 0) {
            // 计算目标计数（正数正转，负数反转）
            const long targetCounts = (COUNTS_PER_360 * inputAngle) / 360;
            
            Serial.print(F("[串口] 转动 "));
            Serial.print(inputAngle);
            Serial.print(F("度 (目标计数: "));
            Serial.print(targetCounts);
            Serial.println(F(")"));
            
            const long startCount = readCount();
            const unsigned long startTime = millis();
            
            // 执行转动（自动处理方向）
            rotateRelativeCounts(targetCounts);
            
            const long actualCounts = readCount() - startCount;
            const unsigned long duration = millis() - startTime;
            
            // 打印结果
            Serial.print(F("  实际计数: "));
            Serial.print(actualCounts);
            Serial.print(F(" | 误差: "));
            Serial.print(actualCounts - targetCounts);
            Serial.print(F(" | 用时: "));
            Serial.print(duration);
            Serial.println(F("ms"));
            
            // 计算实际角度
            const float actualAngle = (actualCounts * 360.0) / COUNTS_PER_360;
            Serial.print(F("  实际角度: "));
            Serial.print(actualAngle, 2);
            Serial.print(F("度 | 累计计数: "));
            Serial.println(readCount());
            Serial.println();
        }
    }
    
    // ===== 按钮触发控制 =====
    // 读取按钮原始状态
    const bool btnNow = digitalRead(PIN_TEST_FIRE_BTN);

    // 检测原始状态变化
    if (btnNow != lastRawState) {
        lastChangeTime = millis();
        lastRawState = btnNow;
    }

    // 防抖：状态稳定超过 DEBOUNCE_MS 后才认为有效
    if ((millis() - lastChangeTime) > DEBOUNCE_MS) {
        // 检测稳定状态变化
        if (btnNow != lastStableState) {
            Serial.print(F("[BTN] 稳定状态变化: "));
            Serial.println(btnNow ? F("HIGH") : F("LOW"));
            
            // 检测上升沿（LOW -> HIGH）
            if (lastStableState == LOW && btnNow == HIGH) {
                launchCounter++;

                // 计算目标计数
                const long targetCounts = (COUNTS_PER_360 * LAUNCH_ANGLE) / 360;

                Serial.print(F("[#"));
                Serial.print(launchCounter);
                Serial.print(F("] 发射！转动 "));
                Serial.print(LAUNCH_ANGLE);
                Serial.print(F("度 (目标计数: "));
                Serial.print(targetCounts);
                Serial.println(F(")"));

                const long startCount = readCount();
                const unsigned long startTime = millis();

                // 执行发射动作
                rotateRelativeCounts(targetCounts);

                const long actualCounts = readCount() - startCount;
                const unsigned long duration = millis() - startTime;

                // 打印结果
                Serial.print(F("  实际计数: "));
                Serial.print(actualCounts);
                Serial.print(F(" | 误差: "));
                Serial.print(actualCounts - targetCounts);
                Serial.print(F(" | 用时: "));
                Serial.print(duration);
                Serial.println(F("ms"));

                // 计算实际角度
                const float actualAngle = (actualCounts * 360.0) / COUNTS_PER_360;
                Serial.print(F("  实际角度: "));
                Serial.print(actualAngle, 2);
                Serial.print(F("度 | 累计计数: "));
                Serial.println(readCount());
                Serial.println();
            }
            
            lastStableState = btnNow;
        }
    }

    delay(10);
}
